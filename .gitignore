# Deps and packaged builds — 830MB+ combined, never commit.
node_modules/
dist/

# Generated by `npm run screenshot` (the committed copy is assets/screenshot.png).
flourish-screenshot.png

# Stamped per-build by tools/stamp.js from the live git checkout. Committing it
# would mean the file says whatever the last commit said, which is the exact
# drift it exists to expose.
src/build-info.js
build-info.json

# Written by server.js at runtime (cwd/model/demoMode). Machine state, not
# source — and if it were tracked, every settings change would mark the build
# dirty and the stamp's "+" would stop meaning anything.
.flourish-config.json

# Saved SSH settings live in Electron's userData dir, not here — nothing to ignore.
